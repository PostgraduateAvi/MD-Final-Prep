{
  "repository": "MD-Final-Prep",
  "description": "Medical study materials and processed data for MD exam preparation",
  "version": "1.0.0",
  "created": "2024-07-26",
  "structure": {
    "data/": {
      "description": "Processed data outputs and question papers",
      "files": {
        "tokenized_content.json": {
          "description": "Detailed tokenization results with text chunks from all PDF materials",
          "type": "json",
          "size_tokens": "19.2M",
          "unique_tokens": "6.1M",
          "generated_by": "scripts/simple_tokenize.py"
        },
        "token_summary.csv": {
          "description": "Summary statistics for all processed files",
          "type": "csv",
          "generated_by": "scripts/simple_tokenize.py"
        }
      },
      "subdirectories": {
        "question_papers/": {
          "description": "Past year question papers and exams in Excel format",
          "file_count": 25,
          "file_types": [".xlsx"],
          "categories": [
            "Basic Science papers (2016-2024)",
            "Systemic Medicine papers (2017-2025)", 
            "Infectious Diseases papers (2019-2024)",
            "Recent Advances papers (2020-2024)"
          ]
        }
      }
    },
    "PDFs/": {
      "description": "Medical study materials in PDF format",
      "subdirectories": {
        "Harrison_Textbooks/": {
          "description": "Harrison's Internal Medicine textbook sections",
          "file_count": 10,
          "categories": [
            "Cardiology", "Nephrology", "Endocrinology", 
            "Gastroenterology", "Neurology", "Haematology",
            "Rheumatology", "Respiratory System", "General Medicine",
            "Infectious Diseases"
          ]
        },
        "Guidelines/": {
          "description": "Medical guidelines and protocols",
          "file_count": 13,
          "organizations": [
            "ADA (American Diabetes Association)",
            "KDIGO (Kidney Disease: Improving Global Outcomes)",
            "IDSA (Infectious Diseases Society of America)"
          ]
        },
        "Neurology_Textbooks/": {
          "description": "Specialized neurology study materials",
          "file_count": 8,
          "topics": [
            "Motor System", "Cranial Nerves", "Cortical Functions",
            "Brainstem and Cranial Nerve Syndromes", "Autonomous Nervous System",
            "Coordination and Gait", "General Neurology", "Archit Neurology Section"
          ]
        }
      }
    },
    "scripts/": {
      "description": "Python scripts for content processing and navigation",
      "files": {
        "simple_tokenize.py": {
          "description": "Main tokenization script using built-in Python libraries",
          "dependencies": ["PyPDF2", "pandas", "openpyxl"]
        },
        "tokenize_content.py": {
          "description": "Advanced tokenization script with tiktoken support",
          "dependencies": ["PyPDF2", "pandas", "tiktoken"]
        },
        "navigate_content.py": {
          "description": "Content navigator for exploring repository structure",
          "dependencies": ["json", "pathlib"]
        }
      }
    }
  },
  "usage": {
    "tokenization": "Run 'python scripts/simple_tokenize.py' to process all content",
    "navigation": "Run 'python scripts/navigate_content.py' to explore structure",
    "output_location": "Processed data is saved in data/ directory"
  },
  "statistics": {
    "total_files": 56,
    "total_size": "278 MB",
    "total_tokens": "19.2M",
    "unique_tokens": "6.1M"
  }
}